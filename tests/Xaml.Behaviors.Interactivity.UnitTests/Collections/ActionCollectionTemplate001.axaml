<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Avalonia.Xaml.Interactivity.UnitTests.ActionCollectionTemplate001"
        Title="ActionCollectionTemplate001">
  <Window.Resources>
    <SolidColorBrush x:Key="RedBrush" Color="Red" />
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Button.red">
      <Setter Property="(Interaction.Behaviors)">
        <BehaviorCollectionTemplate>
          <BehaviorCollection>
            <EventTriggerBehavior EventName="Click">
              <EventTriggerBehavior.Styles>
                <Style Selector="EventTriggerBehavior">
                  <Setter Property="Actions">
                    <ActionCollectionTemplate>
                      <ActionCollection>
                        <ChangePropertyAction PropertyName="Background"
                                              Value="{StaticResource RedBrush}" />
                      </ActionCollection>
                    </ActionCollectionTemplate>
                  </Setter>
                </Style>
              </EventTriggerBehavior.Styles>
            </EventTriggerBehavior>
          </BehaviorCollection>
        </BehaviorCollectionTemplate>
      </Setter>
    </Style>
  </Window.Styles>
  <StackPanel Spacing="8">
    <Button Name="TargetButton1" Classes="red" Background="Transparent" Content="Item1" />
    <Button Name="TargetButton2" Classes="red" Background="Transparent" Content="Item2" />
    <Button Name="TargetButton3" Classes="red" Background="Transparent" Content="Item3" />
  </StackPanel>
</Window>
